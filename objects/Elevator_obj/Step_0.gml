if(tick==0){
if(y<starty+range&&!instance_position(x,y+25,Solid)){
y+=sped
}else{
tick=1
}}else{
if(y>starty-range&&!instance_position(x,y-16,Solid)){
y-=sped
}else{
tick=0
}}
if(tick==0){
if(instance_place(x,y-2,Me)){
Me.y+=sped
}}
if(instance_place(x,y,Me)){
while(instance_place(x,y,Me)){
if(tick==0){
if(y-5<=Me.y){
Me.y+=1
}else{
Me.y-=1
}}else{
Me.y-=1
}}
with(Me){
if(instance_place(x,y,Solid)){
Control.healthcon=0
}}}

