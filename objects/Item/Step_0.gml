if(x>__view_get( e__VW.XView, 0 )-10&&x<__view_get( e__VW.XView, 0 )+__view_get( e__VW.WView, 0 )+10&&y>__view_get( e__VW.YView, 0 )-90&&y<__view_get( e__VW.YView, 0 )+__view_get( e__VW.HView, 0 )+10){
if(check==1){
//Experience
if(itemtype==1){
nograv=1
sprite_index=exp_spr
pull=30
image_speed=0.05
sped=0.5
}else{
//Coin
if(itemtype==2){
if(subtype==0){
sprite_index=moneyitem
image_speed=0.075
}else{
if(subtype==1){
image_index=4
image_speed=0
sprite_index=life
}else{
}}
pull=20
}else{
//Brain
if(itemtype==3){
sprite_index=moneyitem
pull=-1
image_index=6
}else{
//Dream Bottle
if(itemtype==4){
snd1=dreambottle_snd1
nograv=1
keep=1
sprite_index=items_spr
pull=10
image_index=2
image_speed=0.15
hp=1
imagenum=2
tick=0
startx=x
starty=y
}else{
//Save Book
if(itemtype==5){
pull=-1
snd1=dreambottle_snd1
nograv=1
keep=1
sprite_index=savebook_spr
image_index=0
image_speed=0
hp=1
tick=0
startx=x
starty=y
}else{
//Key
if(itemtype==10){
snd1=key_snd1
keep=1
sprite_index=items_spr
pull=10
image_speed=0
image_index=0
}
}}}}}
check=0
}

//***{ALWAYS}***

//Exp
if(itemtype==1){
image_angle+=2.5
if(x<Me.x+8){
x+=sped
}else{
if(x>Me.x+12){
x-=sped
}}
if(y<Me.y+10){
y+=sped
}else{
if(y>Me.y+14){
y-=sped
}}
}else{
//Coin
if(itemtype==2){
if(subtype==0){
if(respace>0){
if(instance_place(x,y,Item)){
respace-=1
chance=choose(1,-1)
if(!place_meeting(x+chance,y,Solid)){
x+=chance
}
if(!place_meeting(x,y+chance,Solid)){
y+=chance
}}}
if(image_index>=3){
image_index=0
}else{
if(image_index<=1){
image_speed=0.005
}else{
image_speed=0.075
}}}}else{

//Dream Bottle
if(itemtype==4){
if(image_index>imagenum+2||image_index<imagenum){
image_index=imagenum
}

if(tick==0){
if(y<starty+5){
y+=0.15
}else{
tick=1
}}else{
if(y>starty-5){
y-=0.15
}else{
tick=0
}}}}
}

if(nograv==0){
if(!instance_place(x,y+1,Solid)){
y+=1
}
if(respace>0){
//if(instance_place(x,y,Solid)){
//y-=1
}}
//}

if(itemtype==2&&subtype==1){
if(Me.hp<Me.hptotal){
pull=10
}else{
opened=0
pull=0
}}

if(pull>0){
if(opened==1){
if(itemtype==1){
Control.maskArray[Control.charArray[Control.charselected,8],1]+=1
}else{
if(itemtype==2){
if(subtype==0){
Control.charArray[Control.charselected,11]+=1
Control.charArray[Control.charselected,12]+=1
Control.levelgold+=1
Control.drawvar1+=1
Control.drawvar2=40
}else{
if(subtype==1){
with(Me){
if(hp<hptotal){
hp+=4
if(hp>hptotal){
hp=hptotal
}}}
}else{

}}}else{
if(itemtype==4){
with(Control){
levelsArray[owLevels[charArray[charselected,6],charArray[charselected,7]]+actchoose-1,other.iden]=1
}
}else{
if(itemtype==10){
Dummy_obj.key+=1
}}}}
if(audio_is_playing(snd1)){
audio_stop_sound(snd1)
audio_play_sound(snd1,8,false)
}else{
audio_play_sound(snd1,8,false)
}
instance_destroy()
}
if(x-(Me.x+8)<=pull&&x-(Me.x+8)>=-pull&&y-(Me.y+12)<=pull&&y-(Me.y+12)>=-pull){
if(x<Me.x+8){
hsp=0.3
}else{
hsp=-0.3
}

if(y<Me.y+12){
vsp=0.3
}else{
vsp=-0.3
}}else{
if(hsp>0){
hsp-=0.0025
}
if(hsp<0){
hsp+=0.0025
}}
}else{
//Save Book
if(itemtype==5){
if(tick==0){
if(y<starty+3){
y+=0.15
}else{
tick=1
}}else{
if(y>starty-3){
y-=0.15
}else{
tick=0
}}
if(opened==1){
image_index=1
Control.charArray[Control.charselected,3]=startx
Control.charArray[Control.charselected,4]=starty-4
Control.cpsave=1
}}}

if(y>room_height){
instance_destroy()
}

if(keep==0){
if(duration>0){
duration-=1
}else{
instance_destroy()
}
}}

