	}
	with(legone){
	instance_destroy()
	}
	with(legtwo){
	instance_destroy()
	}
	with(armone){
	instance_destroy()
	}
	with(armtwo){
	instance_destroy()
	}
	}else{
	mask_index=sprite_index

	//Phase One
	if(phase==1){
	if(tick==0){
	if(xlocation<0+range){
	xlocation+=sped
	x+=sped
	}else{
	tick=1

	dir=1
