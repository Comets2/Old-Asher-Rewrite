	}
	if(mecheck==0){
	simplemove_scr(1)
	selfcreated.y=y+16
	}else{
	mecheck=0
	}
	if(selfcreated.hp>1){
	with(selfcreated){
	if(instance_place(x,y+1,Me)){
	hurttick=1
	}
	//ROLL
	if(delay<=0){
	if(hurttick==0){
	if(imagesave<imagemax-0.07+imagelevel){
	imagesave+=0.035
	//imagesave+=0.05+imagelevel
	}else{
	imagesave=0
	}
	imagecheck=floor(imagesave)
	if(imagecheck!=clockcheck){
	clock=0
	clockcheck=imagecheck
	}else{
	clock+=0.15
	}
	selfcreated.image_index=loot_array[imagecheck]
	selfcreated.y=y+9+clock
	}else{
	if(!audio_is_playing(box1_snd)){
	audio_play_sound(box1_snd,1,false)
	}else{
	audio_stop_sound(box1_snd)
	audio_play_sound(box1_snd,1,false)
	}
	hurttick=0
	delay=delaytotal
	}}else{
	//Loot
	delay-=1
	if(selfcreated.y>y+12-0.15&&selfcreated.y<y+12+0.15){
	selfcreated.y=y+12
	}else{
	if(selfcreated.y<y+12-0.15){
	selfcreated.y+=0.15
	}else{
	if(selfcreated.y>y+12+0.15){
	selfcreated.y-=0.15
	}}}
	imagecheck=floor(imagesave)
	if(delay==delaytotal/2){

	if(other.answer==imagecheck){
	other.correct=1
	}else{
	other.correct=2
	}
	other.phase=4
	}else{
	if(delay==0){
	}}}

	}
	if(!instance_exists(selfcreated)){
	phase=1
	duration=60
	image_index=1
	selfcreated=0
	}

	}}else{
	if(phase==3){
	correct=0
	hurttick=0
	phase=0
	selfcreated.delay=0
	selfcreated.hurttick=0
	selfcreated.correct=0
	}
	}}else{

	//--------------------------------------------------------------------<<<<<<{RANDOM BLOCK}>>>>>>--------------------------------------------------------------------
	if(enemytype==10){
	if(phase==0){
	if(check==1){
	tick=choose(0,1)
	movingcheck=0
	mecheck=0
	hp=10
	check=0
	damaging=0
	duration=240
	image_speed=0
	sprite_index=present_randomballoon_spr
	mask_index=dummy_spr
	range=0.5
	movespeed=0.005
	moving=0

	selfcreated=instance_create(x-9,y+16,Container)
	with(selfcreated){
	if(other.subtype==0){
	imagemax=3
	}else{
	imagemax=4
	}
	imagesave=irandom(imagemax)
	image_index=imagesave
	clock=0
	clockcheck=imagesave
	for(i=0;i<imagemax;i+=1){
	loot_array[i]=i
	}
	depth=other.depth
	imagelevel=0
	delay=0
	delaytotal=80
	subtype=70
	creator=other.id
	nograv=1
	startx=x
	starty=y
	bomb=0
	sprite_index=present_randomblock_spr
	selfcreated=instance_create(x+8,y+8,Dummy_two_object)
	with(selfcreated){
	depth=other.depth
	pin=70
	starty=2
	image_speed=0
	sprite_index=present_randomitem_spr
	}
	mask_index=sprite_index
	}
	depth=selfcreated.depth+2
	}
	if(mecheck==0){
	simplemove_scr(1)
	selfcreated.y=y+16
	}else{
	mecheck=0
	}
	if(selfcreated.hp>1){
	with(selfcreated){
	//ROLL
	if(delay<=0){
	if(hurttick==0){
	if(imagesave<imagemax-0.07+imagelevel){
	imagesave+=0.035
	//imagesave+=0.05+imagelevel
	}else{
	imagesave=0
	}
	imagecheck=floor(imagesave)
	if(imagecheck!=clockcheck){
	clock=0
	clockcheck=imagecheck
	}else{
	clock+=0.15
	}
	selfcreated.image_index=loot_array[imagecheck]
	selfcreated.y=y+9+clock
	}else{
	if(!audio_is_playing(box1_snd)){
	audio_play_sound(box1_snd,1,false)
	}else{
	audio_stop_sound(box1_snd)
	audio_play_sound(box1_snd,1,false)
	}
	hurttick=0
	delay=delaytotal
	}}else{
	//Loot
	delay-=1
	if(selfcreated.y>y+12-0.15&&selfcreated.y<y+12+0.15){
	selfcreated.y=y+12
	}else{
	if(selfcreated.y<y+12-0.15){
	selfcreated.y+=0.15
	}else{
	if(selfcreated.y>y+12+0.15){
	selfcreated.y-=0.15
	}}}
	imagecheck=floor(imagesave)
	if(delay==delaytotal/2){
	//Bomb
	if(loot_array[imagecheck]==0){
	bomb=5
	}else{
	//Coin
	if(loot_array[imagecheck]==1){
	created=instance_create(x+(sprite_width/2)-1,y+sprite_height+3,Item)
	created.itemtype=2
	}else{
	//Tri Coin
	if(loot_array[imagecheck]==2){
	for(i=0;i<3;i+=1){
	created=instance_create(x+(sprite_width/2)-1,y+sprite_height+3,Item)
	created.itemtype=2
	}
	}else{
	//Heart
	if(loot_array[floor(imagecheck)]==3){
	created=instance_create(x+(sprite_width/2)-1,y+sprite_height+3,Item)
	created.itemtype=2
	created.subtype=1
	}}}
	}
	loot_array[imagecheck]=0
	selfcreated.image_index=0
	hurttick=0
	selfcreated.image_index=loot_array[imagecheck]
	}else{
	if(delay==0){
	}}}
	if(bomb!=0){
	//BLOWS UP
	if(bomb>1){
	Control.screenshake+=8
	bomb-=1
	audio_play_sound_at(choose(pump_abil1_snd1,pump_abil1_snd2),x,y, 0, 90, 150, 0.5, false, 1)

	chance=irandom(sprite_get_number(present_fetti_spr))
	for(i=20;i>0;i-=1){
	//CONFETTI BLAST
	created=instance_create(x+5,y+5,Dummy_object)
	with(created){
	sprite_index=present_fetti_spr
	mask_index=sprite_index
	image_speed=0
	image_index=other.chance+other.i
	direction=other.i*20
	direction+=(other.delay-1)*10
	tick=0
	angle=random(10)*choose(-1,1)
	startangle=0
	image_angle=direction
	speed=random_range(0.55,0.8)
	duration=120+random(80)
	damage=1
	pin=73
	}}}else{
	with(selfcreated){
	instance_destroy()
	}
	instance_destroy()
	}}
	}
	if(!instance_exists(selfcreated)){
	phase=1
	duration=120
	image_index=1
	selfcreated=0
	}

	}}else{
	if(duration>0){
	duration-=1
	y-=1
	}else{
	instance_destroy()
	}
	}}else{

	//--------------------------------------------------------------------<<<<<<{Pirate Para}>>>>>>--------------------------------------------------------------------
	if(enemytype==11){
	if(check==1){
	check=0
	sprite_index=pirate_two_para_spr
	mask_index=sprite_index
	image_speed=0.1
	}
	if(!instance_place(x,y+1,Solid)){
	y+=1
	}else{
	created=instance_create(x,y,Enemy)
	with(created){
	enemytype=1
	y+=7
	}
	instance_destroy()
	}

	}}}}}}}}}}
	}





}
