function worldtwo_rm1_enemy_scr() {
	if(check==1){
	imgnum=0
	}

	//--------------------------------------------------------------------*****************{Anchor Pirate}*****************--------------------------------------------------------------------
	if(enemytype==2){
	//*****{PHASE:0}*****
	if(x+8>Me.x-10&&x+8<Me.x+20){
	sprite_index=pirate_four_climb2_spr
	}else{
	if(x+8<Me.x+10){
	sprite_index=pirate_four_climb1_spr
	}else{
	sprite_index=pirate_four_climb3_spr
	}}
	if(phase==0){
	if(check==1){
	image_speed=0.05
	check=0
	phase=0
	selfcreated=instance_create(x+15,y+9,Dummy_object)
	with(selfcreated){
	depth=8
	direction=270
	image_angle=direction
	sprite_index=anchor_spr
	pin=70
	creator=id
	durationtotal=120
	duration=0
	startx=x
	starty=y
	damage=1
	}
	sprite_index=pirate_four_climb1_spr
	mask_index=sprite_index
	attcd=60
	}


	if(attcd>0){
	attcd-=1
	}else{
	phase=1
	check=1
	}
	}else{

	//*****{PHASE:1}*****
	if(phase==1){
	if(check==1){
	if(point_distance(x+8,y+8,Me.x+10,Me.y+10)<90){
	check=0
	with(selfcreated){
	direction=point_direction(x,y,Me.x,Me.y)
	endx=Me.x+10
	endy=Me.y+10
	endx+=Me.hsp*6
	endy+=Me.vsp*2
	if(x<Me.x){
	endx+=5
	}else{
	if(x>Me.x+20){
	endx-=5
	}}
	if(y<Me.y){
	endy+=5
	}else{
	if(y>Me.y+20){
	endy-=5
	}}
	image_angle=direction
	duration=80
	tick=0
	durationtotal=duration
	}}}else{

	with(selfcreated){
	if(duration>0){
	duration-=1
	if(duration>=floor(durationtotal*.75)){
	if(x<endx-7){
	x+=3
	}else{
	if(x>endx+7){
	x-=3
	}}
	if(y<endy-7){
	y+=3
	}else{
	if(y>endy+7){
	y-=3
	}}
	image_angle=direction
	if(x<startx-5){
	//x+=2
	y+=0.5
	}else{
	if(x>startx+5){
	//x-=2
	y+=0.5
	}}
	}else{
	if(duration==floor(durationtotal*.75)-1){
	}else{
	if(duration<=floor(durationtotal*.75)-1){
	direction=point_direction(x,y,startx,starty)+180
	image_angle=direction
	if(y<starty-4){
	y+=0.875
	}else{
	if(y>starty+4){
	y-=0.875
	}}
	if(x<startx-4){
	x+=2
	}else{
	if(x>startx+4){
	x-=2
	}}}
	}}}else{
	other.phase=0
	other.attcd=120
	direction=270
	image_angle=direction
	duration=0
	x=startx
	y=starty
	}}}}}
	}else{

	//--------------------------------------------------------------------*****************{Swordsman Pirate}*****************--------------------------------------------------------------------
	if(enemytype==1){
	//Walk Phase
	if(phase==0){
	if(check==1){
	check=0
	y+=1
	hp=5
	tick=0
	startx=x 
	image_speed=0.125
	sped=0.75
	range=64
	sprite_index=pirate_two_spr
