	attcd=240
	phase=0
	selfcreated=instance_create(x,y,Dummy_two_object)
	with(selfcreated){
	damage=1
	sprite_index=pirate_sword_spr
	depth=other.depth-1
	image_index=0
	pin=61
	}}
	if(room==Worldtwo_rm1_part2){
	hit=instance_place(x+8,y+1,Solid)
	if(hit==noone){
	if(tick==0){
	tick=1
	dir=1
	selfcreated.image_xscale=-1
	x-=sped
	}else{
	tick=0
	dir=0
	selfcreated.image_xscale=1
	x+=sped
	}}else{
	if(hit.image_index!=0&&hit.image_index!=1&&hit.image_index!=8){
	with(selfcreated){
	instance_destroy()
	}
	instance_destroy()
	}}}

	with(selfcreated){
	if(other.image_index<1){
	if(other.dir==0){
	x=other.x+6
	image_angle=355
	}else{
	x=other.x+9
	image_angle=5
	}
	y=other.y+13
	}else{
