	if(other.dir==0){
	x=other.x+8
	image_angle=345
	}else{
	x=other.x+7
	image_angle=15
	}
	y=other.y+12
	}}}}
	sprite_index=pirate_sword_spr
	image_index=0
	}

	if(tick==0){
	if(x<startx+range){
	x+=sped
	}else{
	tick=1
	dir=1
	selfcreated.image_xscale=-1
	}}else{
	if(x>startx-range){
	x-=sped
	}else{
	tick=0
	dir=0
	selfcreated.image_xscale=1
	}}

	if(attcd==0){
	phase=1
	check=1
	}

	}else{
	//Lunge Phase
	if(phase==1){

	}}
	}else{

	//--------------------------------------------------------------------*****************{Parrot}*****************--------------------------------------------------------------------
