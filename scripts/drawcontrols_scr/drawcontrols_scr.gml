	draw_text_ext_transformed_colour(drawxpos+20+114,drawypos+60+30,"Short Hop",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)

	draw_text_ext_transformed_colour(drawxpos+58+114,drawypos+60,"Arrows",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)
	draw_text_ext_transformed_colour(drawxpos+58+114,drawypos+60+10,"Space",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)
