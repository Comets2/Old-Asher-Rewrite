function drawcontrols_scr() {
	drawxpos= __view_get( e__VW.XView, 0 )
	drawypos= __view_get( e__VW.YView, 0 )


	draw_text_ext_transformed_colour(drawxpos+41+4,drawypos+26+1,"Menu Controls",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)

	draw_text_ext_transformed_colour(drawxpos+25,drawypos+45,"Option",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)
	draw_text_ext_transformed_colour(drawxpos+57,drawypos+42,"Keyboard",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)
