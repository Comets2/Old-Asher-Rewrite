	draw_text_ext_transformed_colour(drawxpos+58,drawypos+60+10,"Enter E",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)
	draw_text_ext_transformed_colour(drawxpos+58,drawypos+60+20,"Esc W",1,1000,0.5,0.5,0,c_white,c_white,c_white,c_white,1)
