	image_index=choose(2,3)
	}
	*/
	hsp=other.hsp*-1/8
	vsp=other.vsp*-1/8
	duration=14+irandom(6)
	}}
	}
	if(dir==0){
	image_angle+=4
	}else{
	image_angle-=4
	}
