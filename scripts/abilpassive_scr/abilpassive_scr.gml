	Control.charEquip[Control.charselected,2]=0
	}else{
	Control.helmanimspr=tree_anim2_spr
	Control.charEquip[Control.charselected,6]=7
	Control.charEquip[Control.charselected,2]=8
	}}
	}

	}else{
	//-------------------------------------------------<<**********<<{BURGER BOY}>>**********>>-------------------------------------------------
	if(argument0==5){
	if(abilpassive==1){
	manaregen=0.175
	abilpassive=2
	passivetick=0
	abilpassivedraw=1
	passiveticktwo=0
	passivetickthree=0
