	}}
	instance_destroy()
	}
	if(target==-2){
	x+=hsp
	y+=vsp

	}}}}
	}}}


	//GROUNDED
	if(grounded==1){
	Control.charcdArray[charid,2]=0
	}

	}else{
	//-------------------------------------------------<<**********<<{TREE}>>**********>>-------------------------------------------------
