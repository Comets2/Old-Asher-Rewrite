	if(instance_place(x,y+1,Solid)){
	y-=1
	}
	}else{
	if(instance_place(x+hsp,y,Solid)){
	hsp=hsp*-0.9
	if(dir==0){
	dir=1
	}else{
	dir=0
	}}}}}else{
	}}else{
	delay-=1
	}}else{
	//acornparts
	if(pin==111){
