	}}

	}else{
	if(abilpassive==2){
	if(justhurt==1){
	passiveticktwo=1
	}
	if(passiveticktwo==1){
	justhurt=0
	passivehit=instance_place(x,y+1,Solid)
	passivehittwo=instance_place(x,y+1,Dummy_three_object)
	if(passivehit!=noone&&passivehittwo==noone){
	if(passivehit.sprite_index=solid_spr||passivehit.sprite_index=noslope_spr){
	passiveticktwo=0
