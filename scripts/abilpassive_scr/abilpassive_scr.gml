	hit=instance_place(x,y,Solid)
	if(hit!=noone){
	if(hit.solidtype==3){
	hit.hurttick=1
	instance_destroy()
	}}
	if(delay<=0){
	if(bounce>0){
	if(instance_place(x+hsp,y+vsp+gravamount,Solid)){
	sfx_play_at(choose(snd_burger_fries_hit1,snd_burger_fries_hit2),x,y, 0, 90, 150, 0.5, false, 1) 
	//bounce-=1
	delay=0
	if(instance_place(x,y+vsp+gravamount,Solid)){
	vsp=(vsp+gravamount)*-choose(0.75,0.80)
	hsp=hsp*choose(0.8,0.85,0.9)
