function abilpassive_scr(argument0) {
	if(Control.pause==0&&room!=Overworld_rm){
	if(Control.maskArray[Control.charArray[Control.charselected,8],0]>=999){
	pet_scr(argument0)
	}

	//Control.charArray[Control.charselected,11]=1000
	//Control.charArray[Control.charselected,12]=1000

	//-------------------------------------------------<<**********<<{MINER}>>**********>>-------------------------------------------------
	if(argument0==0){
	if(abilpassive==1){
	manaregen=0.25
	abilpassive=0
	abilpassivedraw=0
	}

	}else{
	//-------------------------------------------------<<**********<<{WIZARD}>>**********>>-------------------------------------------------
	if(argument0==1){
	if(abilpassive==1){
	manaregen=0.25
	abilpassive=0
	abilpassivedraw=0
	}

	with(Dummy_two_object){
	//Spell Trail
	if(pin==555){
	x+=hsp
	y+=vsp
	if(duration>0){
	duration-=1

	if(duration==floor(durationtotal/2)){
	image_index+=1
	}
	}else{
	instance_destroy()
	}}
	}

	}else{
	//-------------------------------------------------<<**********<<{SKELETON}>>**********>>-------------------------------------------------
	if(argument0==2){
	if(abilpassive==1){
	manaregen=0.25
	abilpassive=0
	abilpassivedraw=0
	}

	}else{
	//-------------------------------------------------<<**********<<{BEE}>>**********>>-------------------------------------------------
	if(argument0==3){
	if(abilpassive==1){
	manaregen=0.25
	abilpassive=0
	abilpassivedraw=0
	abilpassivespell=instance_create(x,y,Dummy_two_object)
	with(abilpassivespell){
	updown=0
	abilspelly=0
	abilspelltick=0
	pin=120
	ticksavex=0
	ticksavey=0
	for(i=0;i<11;i+=1){
	if(i==0){
	xoffset=-1+random(2)
	yoffset=-6+random(2)
	ticksavex=-1
	ticksavey=0
	}else{
	if(i==1){
	xoffset=-1+random(2)
	yoffset=-1+random(2)
	ticksavex=-1
	ticksavey=-1
	}else{
	if(i==2){
	xoffset=-1+random(2)
	yoffset=4+random(2)
	ticksavex=-1
	ticksavey=1
	}else{
	if(i==3){
	xoffset=-6+random(2)
	yoffset=-3.5+random(2)
	ticksavex=0
	ticksavey=0
	}else{
	if(i==4){
	xoffset=-6+random(2)
	yoffset=1.5+random(2)
	ticksavex=0
	ticksavey=1
	}else{
	if(i==5){
	xoffset=4+random(2)
	yoffset=-3.5+random(2)
	ticksavex=1
	ticksavey=0
	}else{
	if(i==6){
	xoffset=4+random(2)
	yoffset=1.5+random(2)
	ticksavex=1
	ticksavey=1
	}else{
	if(i==7){
	xoffset=-4.25+random(2)
	yoffset=-2.25+random(2)
	ticksavex=1
	ticksavey=0
	}else{
	if(i==8){
	xoffset=2.25+random(2)
	yoffset=0.25+random(2)
	ticksavex=0
	ticksavey=1
	}else{
	if(i==9){
	xoffset=1.25+random(2)
	yoffset=-3.25+random(2)
	ticksavex=1
	ticksavey=1
	}else{
	if(i==10){
	xoffset=-3.25+random(2)
	yoffset=1.25+random(2)
	ticksavex=0
	ticksavey=0
	}}}}}}}}}}}
	created=instance_create(x+xoffset+8,y+yoffset,Dummy_two_object)
	with(created){
	if(other.i==1){
	instance_destroy()
	}
	damage=0.0175
	target=Me

	if(Control.maskArray[Control.charArray[Control.charselected,8],2]==0){
	sprite_index=beesmall_spr
	}else{
	if(Control.maskArray[Control.charArray[Control.charselected,8],2]==1){
	sprite_index=abil_bee_witch_swarm
	image_speed=random_range(0.1,0.125)
	}else{
	sprite_index=abil_bee2
	}}
	pin=100
	hp=1
	duration=340+(other.i*22)
	creator=other.id
	targetsave=0
	yoffset=other.yoffset
	xoffset=other.xoffset
	tickx=other.ticksavex
	ticky=other.ticksavey
	ticksavex=tickx
	ticksavey=ticky
	spellduration=0
	actualx=x
	actualy=y
	dmgsafety=0
	pace=0.05
	targettype=2
	itemhit=0
	damageextra=0
	leash=0
	}}}
	}

	if((abilpassivespell)!=0){
	if(instance_exists((abilpassivespell))){
	with(abilpassivespell){

	if(updown>0){
	updown-=1
	//Up Down
	if(abilspelltick==0){
	if(abilspelly<10){
	if(abilspelly<5){
	Me.vsp=(0.03)*-1
	}else{
	Me.vsp=0
	}
	abilspelly+=1
	}else{
	abilspelltick=1
	}}else{
	if(abilspelly>-10){
	if(abilspelly>-5){
	Me.vsp=0.005
	}else{
	Me.vsp=0
	}
	abilspelly-=1
	}else{
	abilspelltick=0
	}}
	}

	//BEE HIVE BEE
	with(Dummy_two_object){
	if(pin==100){
	if(dmgsafety>0){
	dmgsafety-=1
	}

	if(point_distance(x,y,Me.x+10,Me.y+10)>300){
	if(x>Me.x){
	if(x-Me.x>300){
	x=Me.x+300+10+xoffset
	actualx=x
	tickx=ticksavex
	ticky=ticksavey
	}}else{
	if(Me.x-x>300){
	x=Me.x-300+10+xoffset
	actualx=x
	tickx=ticksavex
	ticky=ticksavey
	}}
	if(y>Me.y){
	if(y-Me.y>300){
	y=Me.y+300+10+yoffset
	actualy=y
	tickx=ticksavex
	ticky=ticksavey
	}}else{
	if(Me.y-y>300){
	y=Me.y-300+10+yoffset
	actualy=y
	tickx=ticksavex
	ticky=ticksavey
	}}
	}
	if(x<__view_get( e__VW.XView, 0 )||x>__view_get( e__VW.XView, 0 )+__view_get( e__VW.WView, 0 )||y<__view_get( e__VW.YView, 0 )-16||y>__view_get( e__VW.YView, 0 )+__view_get( e__VW.HView, 0 )+16){
	if(leash<40){
	leash+=1
	}else{
	leash=0
	//target reset
	target=Me
	targettype=2
	}}else{
	leash=0
	}

	if(!instance_exists(target)){
	target=Me
	targettype=2
	}

	//ME
	if(targettype==2){
	movespeed=1.25
	tox=target.x+10
	toy=target.y-15
	pace=0.05
	other.damageextra=0
	}else{

	//SWARM LIFT
	if(targettype==3){
	if(Me.grounded==1){
	targettype=2
	target=Me
	}else{
	if(point_distance(x,y,Me.x+10,Me.y+20)>15){
	movespeed=7
	}else{
	movespeed=1.25
	}
	tox=target.x+10
	toy=target.y+20
	pace=0.5
	other.damageextra=1
	if(place_meeting(x,y,Me)){
	if(Me.vsp!=-0.05&&Me.grounded==0){
	if(spellduration>0){
	Me.vsp=-0.6
	}else{
	other.updown=6
	}}
	if(Control.con_p_space||Control.conp_p_space){
	Me.vsp=-2.5
	}}}
	}else{

	//HONEY
	movespeed=3
	other.damageextra=0
	tox=target.x
	toy=target.y
	if(target.hsp==0){
	target.eat=2
	}
	if(point_distance(x,y,tox,toy)>20){
	pace=0.25
	}else{
	pace=0.625
	}}}
	extrarange=35
	if(tox<__view_get( e__VW.XView, 0 )-extrarange||tox>__view_get( e__VW.XView, 0 )+__view_get( e__VW.WView, 0 )+extrarange||toy<__view_get( e__VW.YView, 0 )-extrarange||toy>__view_get( e__VW.YView, 0 )+__view_get( e__VW.HView, 0 )+extrarange||target.immune==1){
	//target=Me
	//targettype=2
	}

	if(duration>0){
	duration-=1
	}else{
	//instance_destroy()
	}
	if(actualx<tox+xoffset-movespeed){
	x+=movespeed
	actualx+=movespeed
	image_xscale=1
	}else{
	if(actualx>tox+xoffset+movespeed){
	x-=movespeed
	actualx-=movespeed
	image_xscale=-1
	}}
	if(actualy<toy+yoffset-movespeed){
	y+=movespeed
	actualy+=movespeed
	}else{
	if(actualy>toy+yoffset+movespeed){
	y-=movespeed
	actualy-=movespeed
	}}

	if(tickx!=-1){
	if(tickx==0){
	if(x<actualx+4){
	x+=pace
	}else{
	tickx=1
	}}else{
	if(x>actualx-4){
	x-=pace
	}else{
	tickx=0
	}}}

	if(ticky!=-1){
