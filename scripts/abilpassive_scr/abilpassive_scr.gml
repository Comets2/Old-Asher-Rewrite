	}}
	//instance_destroy()
	}
	if(instance_place(x,y,Solid)){
	instance_destroy()
	}}
	if(duration>0){
	duration-=1
	}else{
	instance_destroy()
	}
	x+=hsp
	y+=vsp
	image_angle-=7.5
	}else{

	//ACORN LEAVES
	if(pin==113){
	if(duration>0){
	duration-=1
	}else{
	instance_destroy()
	}
	x+=hsp
	y+=vsp
	image_angle-=7.5
	other.duration=4
	}
	}}}

	if(hp>=hptotal/2){
	if(Control.maskArray[Control.charArray[Control.charselected,8],2]==0){
	Control.helmanimspr=tree_anim1_spr
	Control.charEquip[Control.charselected,6]=6
	Control.charEquip[Control.charselected,2]=7
	}else{
	if(Control.maskArray[Control.charArray[Control.charselected,8],2]==1){
	Control.helmanimspr=0
	Control.charEquip[Control.charselected,6]=8
