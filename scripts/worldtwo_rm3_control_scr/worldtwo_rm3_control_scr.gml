	if(x>xpos){
	x-=sped
	}else{
	tick=7
	image_angle=90
	image_yscale=-1
	mask_index=sprite_index
	}
	}else{
	if(tick==7){
	if(y>ypos){
	y-=sped
	}else{
	tick=0
	image_angle=0
	image_yscale=1
	mask_index=sprite_index
	}
	}}}}}}}}}else{
	//Cone Attack
	if(pin==42){
	x+=xsped
	y+=ysped
	if(instance_place(x,y,Solid)){
	instance_destroy()
	}}else{
	//Gravestones
	if(pin==46){

	}
	}}

	}
