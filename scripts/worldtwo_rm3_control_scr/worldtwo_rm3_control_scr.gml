	depth=100
	if(other.i==1){
	x=1344
	}
	x+=16
	}}
	}

	//PROJECTILES
	with(Dummy_object){
	//BOSS PROJ 1 wall
	if(pin==40){

	if(tick==0){
	if(y<starty+8){
	y+=0.1
	}else{
	tick=1
	}
	}else{
	if(y>starty-8){
	y-=0.1
	}else{
	tick=0
	}}

	if(sped>0){
