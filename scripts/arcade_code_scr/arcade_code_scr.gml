function arcade_code_scr() {
	//_______________________________----------------<<***{BIRTHDAY}***>>----------------_______________________________
	if(code==2||code==3){
	arcade_birthday_scr()
	}else{

	//_______________________________----------------<<***{HAUNTED}***>>----------------_______________________________
	if(code==4||code==5){
	arcade_haunted_scr()
	}else{

	//_______________________________----------------<<***{HONEY}***>>----------------_______________________________
	if(code==8||code==9){
	arcade_honey_scr()
	}else{

	//_______________________________----------------<<***{CHRISTMAS}***>>----------------_______________________________
	if(code==100){
	arcade_christmas_scr()

	}}}}




}
